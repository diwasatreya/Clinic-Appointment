<div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-800 border-b pb-4 mb-6">
        <i class="fa-solid fa-cog mr-2 text-accent-green"></i>Settings
    </h2>

    <div class="space-y-6">
        <!-- Visibility Status -->
        <div class="border-b pb-6">
            <label class="text-xl font-bold text-gray-800 block mb-3">
                Visibility Status
            </label>
            <div class="flex justify-between items-center p-4 rounded-lg bg-gray-50 border">
                <span class="font-medium text-gray-700" id="status-text">
                    <%= dataClinic.status ? 'Visible to Patients' : 'Hidden from Patients' %>
                </span>
                <div class="relative inline-block w-14 mr-2 align-middle select-none transition duration-200 ease-in">
                    <input type="checkbox" name="toggle" id="status-toggle"
                        class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all"
                        <%= dataClinic.status ? 'checked' : '' %>>
                    <label for="status-toggle"
                        class="toggle-label block overflow-hidden h-6 rounded-full bg-gray-300 cursor-pointer"></label>
                </div>
            </div>
        </div>

        <!-- Approval Status -->
        <div class="border-b pb-6">
            <% if (dataClinic.approved) { %>
                <!-- Approved State -->
                <div class="mb-4 p-4 rounded-lg bg-green-50 border border-green-200">
                    <div class="flex items-center mb-2">
                        <i class="fa-solid fa-check-circle text-green-600 mr-2"></i>
                        <span class="font-semibold text-green-800">Approved</span>
                    </div>
                    <p class="text-sm text-green-700">Your clinic is approved and visible to patients.</p>
                </div>
                <div class="bg-gray-200 text-gray-600 font-extrabold py-3 px-6 rounded-xl uppercase tracking-wider text-center">
                    <i class="fa-solid fa-check-circle mr-2"></i>
                    Approved
                </div>
            <% } else if (dataClinic.declineReason && !dataClinic.pendingApproval) { %>
                <!-- Declined State -->
                <div class="mb-4 p-4 rounded-lg bg-red-50 border border-red-200">
                    <div class="flex items-center mb-2">
                        <i class="fa-solid fa-times-circle text-red-600 mr-2"></i>
                        <span class="font-semibold text-red-800">Declined</span>
                    </div>
                    <p class="text-sm text-red-700 mb-3">Your clinic approval request was declined by the administrator.</p>
                    <div class="bg-white rounded-lg p-3 border border-red-100">
                        <p class="text-xs font-semibold text-red-600 uppercase tracking-wide mb-1">
                            <i class="fa-solid fa-message-exclamation mr-1"></i>Reason
                        </p>
                        <p class="text-sm text-gray-800"><%= dataClinic.declineReason %></p>
                    </div>
                </div>
                <form method="post" action="/clinic/approval">
                    <input type="hidden" name="redirectTab" value="settings">
                    <button type="submit"
                        class="bg-accent-green hover:bg-green-700  text-white font-extrabold py-3 px-6 rounded-xl shadow-xl uppercase tracking-wider transition duration-150 transform hover:scale-[1.01]">
                        <i class="fa-solid fa-paper-plane mr-2"></i>
                        Re-submit for Approval
                    </button>
                </form>
            <% } else { %>
                <!-- Pending State -->
                <div class="mb-4 p-4 rounded-lg bg-yellow-50 border border-yellow-200">
                    <div class="flex items-center mb-2">
                        <i class="fa-solid fa-clock text-yellow-600 mr-2"></i>
                        <span class="font-semibold text-yellow-800">Pending Approval</span>
                    </div>
                    <p class="text-sm text-yellow-700">Your clinic is pending approval from administrators.</p>
                </div>
                <% if (!dataClinic.pendingApproval) { %>
                    <form method="post" action="/clinic/approval">
                        <input type="hidden" name="redirectTab" value="settings">
                        <button type="submit"
                            class="bg-accent-green hover:bg-green-700  text-white font-extrabold py-3 px-6 rounded-xl shadow-xl uppercase tracking-wider transition duration-150 transform hover:scale-[1.01]">
                            <i class="fa-solid fa-paper-plane mr-2"></i>
                            Send for Approval
                        </button>
                    </form>
                <% } else { %>
                    <div class="bg-yellow-100 text-yellow-700 font-extrabold py-3 px-6 rounded-xl uppercase tracking-wider text-center">
                        <i class="fa-solid fa-clock mr-2"></i>
                        Awaiting Admin Review
                    </div>
                <% } %>
            <% } %>
        </div>
    </div>
</div>

